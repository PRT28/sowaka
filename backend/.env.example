NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173,http://localhost:8080,https://dikcsyvq9i7v1.cloudfront.net
# Entire Firebase service-account JSON encoded on one line. Keep this secret.
FIREBASE_SERVICE_ACCOUNT_JSON=
# Temporary diagnostic endpoint: POST /notifications/test. Keep false normally.
ENABLE_NOTIFICATION_TEST_ENDPOINT=false
MOBILE_APP_API_BASE_URL=http://10.0.2.2:4000

# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster0.example.mongodb.net/?appName=Cluster0
MONGODB_DB=sowaka

# ESSL SQL Server attendance import (run: npm run attendance:import)
# Prefer these separate values for a named SQL Express instance.
ATTENDANCE_SQL_SERVER=DESKTOP-1N8BDLM
ATTENDANCE_SQL_INSTANCE=SQLEXPRESS01
ATTENDANCE_SQL_DATABASE=etimetracklite1
ATTENDANCE_SQL_USER=your-sql-user
ATTENDANCE_SQL_PASSWORD=your-sql-password
ATTENDANCE_SQL_ENCRYPT=true
ATTENDANCE_SQL_TRUST_SERVER_CERTIFICATE=true
# Alternatively, set ATTENDANCE_SQL_URL and it will take precedence.
# ATTENDANCE_SQL_URL=Server=DESKTOP-1N8BDLM\\SQLEXPRESS01;Database=etimetracklite1;User Id=user;Password=password;Encrypt=true;TrustServerCertificate=true
ATTENDANCE_SQL_TABLE=dbo.Essl_Data
ATTENDANCE_SQL_ID_COLUMN=Sno
ATTENDANCE_SQL_EMPLOYEE_COLUMN=Emp_Code
ATTENDANCE_SQL_DATE_COLUMN=Log_Date
ATTENDANCE_SQL_TIME_COLUMN=Log_Time
ATTENDANCE_SQL_DIRECTION_COLUMN=Direction
ATTENDANCE_SQL_TIMEZONE=+05:30
ATTENDANCE_IMPORT_BATCH_SIZE=500
# Optional overrides for recovery/backfill runs. Normal runs use the persisted
# Sno watermark in MongoDB collection attendance_import_state.
# ATTENDANCE_IMPORT_AFTER_ID=0
# ATTENDANCE_IMPORT_FROM=2026-01-01

# Email OTP
OTP_TTL_MINUTES=10
# For local dev only. Lets /auth/verify-otp accept 123456 and logs generated OTPs.
OTP_DEV_BYPASS=true
AUTH_SESSION_TTL_DAYS=30

# Required by reporting relationship administration endpoints.

# AWS S3 reimbursement receipt storage
# Required: the bucket must already exist and the IAM identity needs s3:PutObject
# and s3:DeleteObject for the prefix below.
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your-private-receipt-bucket
# Leave these blank when the runtime uses an IAM role (recommended in AWS).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional, only for temporary AWS credentials.
AWS_SESSION_TOKEN=
# Optional, only for S3-compatible services/local emulators. Leave blank for AWS S3.
AWS_S3_ENDPOINT=
AWS_S3_FORCE_PATH_STYLE=false
AWS_S3_RECEIPT_PREFIX=reimbursements/receipts
# Use AES256 for SSE-S3 or aws:kms for KMS encryption.
AWS_S3_SERVER_SIDE_ENCRYPTION=AES256
# Required only when AWS_S3_SERVER_SIDE_ENCRYPTION=aws:kms.
AWS_S3_KMS_KEY_ID=

# Zoho SMTP
ZOHO_SMTP_HOST=smtp.zoho.com
ZOHO_SMTP_PORT=465
ZOHO_SMTP_SECURE=true
ZOHO_SMTP_USER=your-address@yourdomain.com
ZOHO_SMTP_PASS=your-zoho-app-password
ZOHO_SMTP_FROM="Sowaka Connect <your-address@yourdomain.com>"
